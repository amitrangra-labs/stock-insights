# Copy this file to `.env` and fill in your own free API keys.
# `.env` is gitignored — never commit real keys.
#
# The app reads these as environment variables (see application.yml). To load them
# into your shell before running:  set -a && source .env && set +a

# Finnhub — free tier: https://finnhub.io/register
# Used for quotes, company profile, news, and analyst recommendation trends.
FINNHUB_API_KEY=

# Alpha Vantage — free tier: https://www.alphavantage.co/support/#api-key
# Secondary source for fundamentals / earnings estimates.
ALPHA_VANTAGE_API_KEY=
